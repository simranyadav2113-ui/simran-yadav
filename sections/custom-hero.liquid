{% comment %}
  SCHEMA FOR DYNAMICALLY ADDING THE NEW CUSTOM HEADER
{% endcomment %}
{% schema %}
{
    "name": "Custom Hero Section",
    "settings": [
        {
            "type": "select",
            "id": "section_width",
            "label": "Section Width",
            "default": "full",
            "options": [
                { "value": "full", "label": "Full Width" },
                { "value": "page", "label": "Page Width" },
            ]
        },
        {
            "type": "image_picker",
            "id": "hero_image",
            "label": "Hero Banner Image"
        },
        {
            "type": "image_picker",
            "id": "hero_image_mob",
            "label": "Hero Banner Image Mobile"
        },
        {
            "type": "select",
            "id": "image_size",
            "label": "Hero Banner Size",
            "options": [
                { "value": "small", "label": "Small" },
                { "value": "medium", "label": "Medium" },
                { "value": "large", "label": "Large" },
                { "value": "auto", "label": "Auto (Image Ratio)" },
            ]
        },
        {
            "type": "header",
            "content": "Banner Content Area"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Banner Heading",
            "placeholder": "Enter Heading Text"
        },
        {
            "type": "textarea",
            "id": "subtext",
            "label": "Banner Sub Content",
            "placeholder": "Enter Content"
        },
        {
            "type": "text",
            "id": "banner_btn_text",
            "label": "Banner Button Text",
            "default": "Shop Now",
        },
        {
            "type": "url",
            "id": "banner_btn_link",
            "label": "Banner Button Link"
        },
        {
            "type": "header",
            "content": "Banner Settings "
        },
        {
            "type": "select",
            "id": "vertical_position",
            "label": "Content Vertical Position",
            "options": [
                { "value": "top", "label": "Top" },
                { "value": "center", "label": "Center" },
                { "value": "bottom", "label": "Buttom" }
            ],
            "default": "center"
        },
        {
            "type": "select",
            "id": "horizontal_position",
            "label": "Content Horizontal Position",
            "options": [
                { "value": "left", "label": "Left" },
                { "value": "center", "label": "Center" },
                { "value": "right", "label": "Right" }
            ],
            "default": "center"
        },
        {
            "type": "color",
            "id": "heading_clr",
            "label": "Banner Heading Color",
            "default": "#000000"
        },
        {
            "type": "color",
            "id": "subtext_clr",
            "label": "Banner Sub Content Color",
            "default": "#000000"
        },
        {
            "type": "color",
            "id": "btn_text_clr",
            "label": "Banner Button Text Color",
            "default": "#FFFFFF"
        },
        {
            "type": "color",
            "id": "btn_bg_blr",
            "label": "Banner Button Background Color",
            "default": "#000000"
        },
        {
            "type": "header",
            "content": "Banner Bottom Strip"
        },
        {
            "type": "text",
            "id": "banner_strip_text",
            "label": "Banner Bottom Strip Text"
        },
        {
            "type": "select",
            "id": "strip_txt_alignment",
            "label": "Strip Text Alignment",
            "options": [
                { "value": "left", "label": "Left" },
                { "value": "center", "label": "Center" },
                { "value": "right", "label": "Right" }
            ],
            "default": "center"
        },
        {
            "type": "color",
            "id": "strip_text_clr",
            "label": "Strip Text Color",
            "default": "#000000"
        },
        {
            "type": "color",
            "id": "strip_bg_clr",
            "label": "Strip Background Color",
            "default": "#dedede"
        }
    ],
    "presets": [
        {
            "name": "Custom Hero Section"
        }
    ]
}
{% endschema %}

{% comment %}
  HTML FOR HEADER WITH DYNAMIC SCHEMA VALUES
{% endcomment %}
<div class="hero-banner size-{{ section.settings.image_size }} {% if section.settings.section_width == "full" %}container-full{% else %}container{% endif %}">
    <!--- Mobile COntent divided heading and subtext starts here ---->
    <div class="hero-content mobile-only
        vertical-{{ section.settings.vertical_position }}
        horizontal-{{ section.settings.horizontal_position }} ">
        
        <h1 style="color: {{ section.settings.heading_clr }};">
            {{ section.settings.heading }}
        </h1>
        <p style="{{ section.settings.subtext_clr }}">
            {{ section.settings.subtext }}
        </p>
    </div>
    {% if section.settings.banner_btn_text != blank %}
        <a href="{{ section.settings.banner_btn_link }}"
            class="hero-btn mobile-only"
            style="
            --btn-text: {{ section.settings.btn_text_clr }};
            --btn-bg: {{ section.settings.btn_bg_blr }};
        ">
            {{ section.settings.banner_btn_text }}
            <span class="arrow"><img src="https://cdn.shopify.com/s/files/1/0782/7934/4313/files/Line_15.png?v=1776453750" alt="icon" width="24" height="24"></span>
        </a>
    {% endif %}
    <!--- Mobile COntent ends here ---->

    <!--- Desktop Banner IMage - hidden on mobile ---->
    {% if section.settings.hero_image != blank %}
        <img src="{{ section.settings.hero_image | image_url: width:2000 }}" 
            width="100" height="100"
            alt="{{ section.settings.hero_image.alt }}"
            class="hero-image desktop-only"
        >
    {% endif %}

    <!--- Mobile Banner IMage - hidden on dekstop ---->
    {% if section.settings.hero_image_mob != blank %}
        <img src="{{ section.settings.hero_image_mob | image_url: width:2000 }}" 
            width="100" height="100"
            alt="{{ section.settings.hero_image_mob.alt }}"
            class="hero-image mobile-only"
        >
    {% endif %}

    <!--- Desktop content - hidden on mobile ---->
    <div class="hero-content desktop-only
        vertical-{{ section.settings.vertical_position }}
        horizontal-{{ section.settings.horizontal_position }} ">
        
        <h1 style="color: {{ section.settings.heading_clr }};">
            {{ section.settings.heading }}
        </h1>
        <p style="{{ section.settings.subtext_clr }}">
            {{ section.settings.subtext }}
        </p>
        {% if section.settings.banner_btn_text != blank %}
            <a href="{{ section.settings.banner_btn_link }}"
                class="hero-btn"
                style="
                --btn-text: {{ section.settings.btn_text_clr }};
                --btn-bg: {{ section.settings.btn_bg_blr }};
        ">
                {{ section.settings.banner_btn_text }}
                <span class="arrow"><img src="https://cdn.shopify.com/s/files/1/0782/7934/4313/files/Line_15.png?v=1776453750" alt="icon" width="24" height="24"></span>
            </a>
        {% endif %}
    </div>
</div>
<div class="banner-strip">
    {{ section.settings.banner_strip_text }}
</div>



{% comment %}
  CSS STARTS HERE ===============================
{% endcomment %}
 <style>
    .container{
        max-width: 1200px;
        margin: 0 auto;
        padding: clamp(16px, 2vw, 24px);
    }
    .container-full{
        width: 100% !important;
        padding: clamp(10px, 1.5vw, 30px);
    }
    .hero-banner{
        position: relative;
        width: 100%;
        overflow: hidden;
    }
    /* Image Sizes */
    .hero-banner.size-small {
        height: clamp(300px, 40vh, 500px);
    }
    .hero-banner.size-medium {
        height: clamp(400px, 60vh, 700px);
    }
    .hero-banner.size-large {
        height: clamp(500px, 80vh, 900px);
    }
    .hero-banner.size-auto {
        height: auto;
    }
    .hero-banner.size-auto  .hero-image{
        height: auto;
    }
    .hero-image{
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .hero-content{
        position: absolute;
        display:flex;
        flex-direction: column;
        gap: clamp(6px, 1vw, 15px);
        max-width: clamp(250px, 30vw, 550px);
    }
    .hero-content h1{
        font-size: clamp(25px, 4vw, 64px);
    }
    .hero-content p{
        font-size: clamp(13px, 1.2vw, 22px);
    }
    .vertical-center.horizontal-center{
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }
    /* Vertical Content Positions */
    .vertical-top{ top:10%; }
    .vertical-center{ top:50%; transform: translateY(-50%); }
    .vertical-bottom{ bottom:10%; }

    /* Horizontal Content Positions */
    .horizontal-left{ left:5%; text-align:left; }
    .horizontal-center{ left:50%; transform: translate(-50%, -50%); text-align:center; }
    .horizontal-right{ right:5%; text-align:right }

    .hero-btn{
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: clamp(8px, 1vw, 14px) clamp(16px, 2vw, 22px);
        background-color: var(--btn-bg);
        color: var(--btn-text);
        text-decoration: none;
        transition: 0.3s ease;
        width: max-content;
        text-transform: uppercase;
        font-size: clamp(12px, 0.9vw, 16px);
    }
    .hero-btn .arrow{
        transition: 0.3s ease;
    }
    .hero-btn:hover .arrow{
        transform: translateX(4px);
        transition: transform 0.3 ease;
    }
    .banner-strip{
        background-color: {{ section.settings.strip_bg_clr }};
        color: {{ section.settings.strip_text_clr }};
        text-align: {{ section.settings.strip_txt_alignment }};
        padding: clamp(6px, 1vw, 12px) 0px;
        text-transform: uppercase;
        font-size: clamp(11px, 0.8vw, 24px);
        font-weight: 500;
    }
    .mobile-only{
        display: none;
    }
    .desktop-only{
        display:block;
    }
    @media (max-width: 1024px){
        .hero-content{
            max-width: 35vw;
        }
    }

    <!--- media queries for responsive viewports -->
    @media (max-width: 768px){
        .mobile-only{
            display: block;
        }
        .desktop-only{
            display:none;
        }
        .hero-content {
            position: relative;
            align-items: center;
            width: 100%;
            left: 0;
            max-width: 100vw;
            align-items: center;
            margin: 0 auto;
            text-align: center;
            padding: clamp(20px, 1vw, 14px) clamp(20px, 2vw, 22px);
        }
        .hero-btn {
            position: absolute;
            bottom: 10%;
            left: 50%;
            transform: translate(-50%, -10%);
            display: flex;
            padding: 2vw 4vw;
        }
        .hero-banner{
            padding: 0px !important;
        }
    }
    @media (min-width: 2560px){
        .header-logo {
            max-height: unset;
            height: 1.5vh;
        }
        .header-center {
            color: var(--text-color);
            font-size: 1.2vw;
        }
        .header-btn{
            padding: 0.8vw 2vw;
            font-size: 1vw;
        }
        .header-btn img{
            width: 2vw;
        }
        .hero-content{
            max-width: 30vw;
        }
        .hero-content h1{
            font-size: 4vw;
             margin-bottom: 0px;
        }
        .hero-content p {
            font-size: 1.2vw;
        }
        .hero-btn{
            padding: 1vw 2vw;
            font-size: 1vw;
        }
    }
 </style>